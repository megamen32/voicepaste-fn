# VoicePaste Fn Environment Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Then source it before running:
#   source .env && ./run.sh

# Required: Your Whisper API endpoint
# Compatible with any OpenAI-compatible Whisper API:
# - OpenAI: https://api.openai.com/v1
# - Self-hosted Whisper servers
# - Third-party Whisper API providers
OPENAI_BASE_URL="https://api.openai.com/v1"

# Required: Your API key
OPENAI_API_KEY="sk-your-key-here"

# Optional: Transcription model (default: whisper-1)
TRANSCRIBE_MODEL="whisper-1"
